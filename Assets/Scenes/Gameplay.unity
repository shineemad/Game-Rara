  m_Script: {fileID: 11500000, guid: c2163f048da8d624286c5daba35a3076, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  lines:
  - speakerName: Narasi
    profile: {fileID: 0}
    text: 'Tiga remaja besar berdiri menghadang di tengah gang.

      Mereka menatap
      Rara sambil tersenyum sinis.'
    choices: []
  - speakerName: Anak Gang
    profile: {fileID: 0}
    text: '"Eh bocah! Lewat sini bayar dulu dong~

      Mana uang jajan lo? HP-nya
      juga sini!"'
    choices: []
  - speakerName: Rara (dalam hati)
    profile: {fileID: 0}
    text: 'Jantung Rara berdebar kencang.

      Mereka mau memalak! Aku harus pilih
      dengan tepat...'
    choices: []
  - speakerName: Rara
    profile: {fileID: 0}
    text: Apa yang harus aku lakukan sekarang?
    choices:
    - label: BALIK ARAH & lari ke jalan ramai sambil teriak "TOLONG!"
      category: AMAN
    - label: Diam, pura-pura tidak dengar sambil terus jalan
      category: RAGU
    - label: Serahkan saja uang & HP biar selamat
      category: BAHAYA
