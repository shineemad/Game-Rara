  m_Script: {fileID: 11500000, guid: c2163f048da8d624286c5daba35a3076, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  lines:
  - speakerName: Pemotor
    profile: {fileID: 0}
    text: Hei adek! Mau bareng om ke sekolah? Naik motor lebih cepat lho daripada
      jalan kaki.
    choices: []
  - speakerName: Pemotor
    profile: {fileID: 0}
    text: Tenang aja, om kenal sama gurumu kok. Ayo cepetan, nanti telat.
    choices:
    - label: Tidak, terima kasih. Saya jalan saja.
      category: AMAN
    - label: Em... siapa Om? Saya tidak kenal.
      category: RAGU
    - label: Boleh, Om! Kebetulan capek.
      category: BAHAYA
