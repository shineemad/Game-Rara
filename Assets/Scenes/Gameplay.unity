  teksWarna: {r: 1, g: 1, b: 1, a: 1}
  namaUkuran: 26
  teksUkuran: 26
  hintTeks: "\u25BC  Klik / SPACE untuk lanjut"
  kecepatanKetik: 0.025
  bolehSkipKetik: 1
  modeVisualNovel: 1
  vnPanelSprite: {fileID: 8288426215254106694, guid: 0ccc85ef2be40fa4897dd6cb20e3e829, type: 3}
  vnPanelTint: {r: 1, g: 1, b: 1, a: 1}
  portraitNarasi: {fileID: -7771728774132427043, guid: 6809b27ca40283248be0310e4d5f4ef1, type: 3}
  portraitRara: {fileID: -307426207498796367, guid: b337f726c99b2184ba032db933c4af66, type: 3}
  portraitPriaAsing: {fileID: 0}
  portraitPakSupir: {fileID: 0}
  vnPortraitPreserveAspect: 1
  vnBoxAnchorMin: {x: 0.014, y: 0.0145}
  vnBoxAnchorMax: {x: 0.986, y: 0.3055}
  vnPortraitAnchorMin: {x: 0.0455, y: 0.304}
  vnPortraitAnchorMax: {x: 0.2345, y: 0.864}
  vnNamaAnchorMin: {x: 0.11, y: 0.11}
  vnNamaAnchorMax: {x: 0.253, y: 0.333}
  vnTeksAnchorMin: {x: 0.31, y: 0.55}
  vnTeksAnchorMax: {x: 0.84, y: 0.76}
  vnNamaWarna: {r: 1, g: 0.85, b: 0.3, a: 1}
  vnTeksWarna: {r: 1, g: 1, b: 1, a: 1}
  vnNamaUkuran: 30
  vnTeksUkuran: 28
  panelIntroAman:
  - speaker: Narasi
    narasi: Rara duduk tepat di belakang Pak Supir, dekat pintu. Dari sini ia bisa
      melihat seluruh isi angkot.
    gambar: {fileID: 0}
    tintGambar: {r: 1, g: 1, b: 1, a: 1}
    latarSprite: {fileID: 0}
  - speaker: Narasi
    narasi: Seorang pria asing yang tadi duduk di bangku belakang berdiri dan pindah,
      ikut merapat di sebelah Rara.
    gambar: {fileID: 0}
    tintGambar: {r: 1, g: 1, b: 1, a: 1}
    latarSprite: {fileID: 0}
  - speaker: Pria Asing
    narasi: Sekolah di mana, dek? Sini deket om aja, biar nggak desak-desakan.
    gambar: {fileID: 0}
    tintGambar: {r: 1, g: 1, b: 1, a: 1}
    latarSprite: {fileID: 0}
  - speaker: Narasi
    narasi: "Tangan pria itu menyentuh bahu Rara! Tapi Pak Supir ada tepat di depan
      \u2014 Rara tahu ia bisa segera minta tolong."
    gambar: {fileID: 0}
    tintGambar: {r: 1, g: 1, b: 1, a: 1}
    latarSprite: {fileID: 0}
  panelIntroRagu:
  - speaker: Narasi
    narasi: Rara duduk berdesakan di tengah, terhimpit di antara ibu-ibu yang membawa
      belanjaan.
    gambar: {fileID: 0}
    tintGambar: {r: 1, g: 1, b: 1, a: 1}
    latarSprite: {fileID: 0}
  - speaker: Narasi
    narasi: Dari bangku belakang, seorang pria asing memaksakan diri duduk di sela
      sempit, merapat ke sisi Rara.
    gambar: {fileID: 0}
    tintGambar: {r: 1, g: 1, b: 1, a: 1}
    latarSprite: {fileID: 0}
  - speaker: Pria Asing
    narasi: Geser dikit dong, dek. Biar om bisa duduk dekat kamu.
    gambar: {fileID: 0}
    tintGambar: {r: 1, g: 1, b: 1, a: 1}
    latarSprite: {fileID: 0}
  - speaker: Narasi
    narasi: Tangan pria itu menyentuh bahu Rara! Ibu-ibu di sekitar mulai melirik,
      tapi Rara terjepit dan susah bergerak.
    gambar: {fileID: 0}
    tintGambar: {r: 1, g: 1, b: 1, a: 1}
    latarSprite: {fileID: 0}
  panelIntroBahaya:
  - speaker: Narasi
    narasi: Rara duduk sendirian di pojok belakang yang sepi. Tak ada penumpang lain
      di dekatnya.
    gambar: {fileID: 0}
    tintGambar: {r: 1, g: 1, b: 1, a: 1}
    latarSprite: {fileID: 0}
  - speaker: Narasi
    narasi: Pria asing yang sejak tadi memperhatikan Rara kini duduk persis di sebelahnya.
      Tak ada seorang pun yang melihat.
    gambar: {fileID: 0}
    tintGambar: {r: 1, g: 1, b: 1, a: 1}
    latarSprite: {fileID: 0}
  - speaker: Pria Asing
    narasi: Tenang, dek... om temani kamu sampai sekolah ya. Deket-deket om aja.
    gambar: {fileID: 0}
    tintGambar: {r: 1, g: 1, b: 1, a: 1}
    latarSprite: {fileID: 0}
  - speaker: Narasi
    narasi: "Tangan pria itu langsung menyentuh bahu Rara! Pojok ini jauh dari Pak
      Supir \u2014 Rara harus berani bertindak sendiri."
    gambar: {fileID: 0}
    tintGambar: {r: 1, g: 1, b: 1, a: 1}
    latarSprite: {fileID: 0}
  judulPilihan: Bahumu disentuh! Apa yang Rara lakukan?
  warnaAman: {r: 0.15, g: 0.68, b: 0.38, a: 1}
  warnaRagu: {r: 0.95, g: 0.62, b: 0.07, a: 1}
  warnaBahaya: {r: 0.91, g: 0.3, b: 0.24, a: 1}
  pilihanList:
  - label: "\u201CJANGAN PEGANG SAYA!\u201D (teriak keras)"
    kategori: AMAN
    reaksi: "\u2713 HEBAT! Rara berani BERSUARA KERAS \u2014 ini kata sakti pertama:
      TIDAK!\nSemua penumpang menoleh ke arah pria itu. Sekarang lanjut: PERGI (pindah)
      & CERITA (lapor Pak Supir)."
    gambarReaksi: {fileID: 0}
    latarReaksi: {fileID: 0}
    kurangiNyawa: 0
    lanjutLapor: 1
  - label: Geser menjauh diam-diam
    kategori: RAGU
    reaksi: "\u26A0 Kamu menggeser badan menjauh, tapi pria itu masih terus mendekat.\nMenjauh
      saja belum cukup. Ingat 3 kata sakti: TIDAK (bersuara tegas) \u2014 PERGI (pindah)
      \u2014 CERITA (lapor Pak Supir)!"
    gambarReaksi: {fileID: 0}
    latarReaksi: {fileID: 0}
    kurangiNyawa: 0
    lanjutLapor: 0
  - label: Diam saja karena takut
    kategori: BAHAYA
    reaksi: "\u2716 Kamu membeku dan diam, jadi pria itu makin berani. Kamu kehilangan
      1 nyawa.\nDiam bukan salahmu \u2014 tapi kamu BISA melindungi diri. Lakukan
      3 kata sakti: TIDAK \u2014 PERGI \u2014 CERITA (lapor Pak Supir)!"
    gambarReaksi: {fileID: 0}
    latarReaksi: {fileID: 0}
    kurangiNyawa: 1
    lanjutLapor: 0
  panelLapor:
  - speaker: Narasi
    narasi: 'Rara langsung berdiri dan PINDAH ke kursi lebih depan, menjauh dari
      pria itu. (Itu kata sakti kedua: PERGI.)'
    gambar: {fileID: 0}
    tintGambar: {r: 1, g: 1, b: 1, a: 1}
    latarSprite: {fileID: 0}
  - speaker: Rara
    narasi: "Aku sudah bersuara dan menjauh. Tapi dia masih satu angkot denganku
      \u2014 aku harus tetap siaga sampai turun."
    gambar: {fileID: 0}
    tintGambar: {r: 1, g: 1, b: 1, a: 1}
    latarSprite: {fileID: 0}
  panelSampaiSekolah: []
  tombolLanjutTeks: "\u25B6  Lanjut"
  warnaLanjut: {r: 0.2, g: 0.62, b: 0.86, a: 1}
  aktifkanVoiceMeter: 1
  kategoriPemicu: AMAN
  gunakanMikrofon: 0
  sensitivitasMic: 12
  ambangKuning: 0.5
  ambangMerah: 0.8
  tahanDetikMerah: 0.6
  isiRate: 0.7
  surutRate: 0.5
  bonusTeriakKeras: 100
  judulTeriak: "\U0001F5E3  TERIAK!"
  instruksiTeriak: "TAHAN tombol & teriak \u201CJANGAN PEGANG SAYA!\u201D sampai
    meter MERAH!"
  teksTombolTeriak: TAHAN UNTUK TERIAK
  labelNormal: Suara Normal  (50-60 dB)
  labelSedang: Suara Sedang  (60-80 dB)
  labelKeras: Suara KERAS  (>80 dB)
  labelBerhasil: "\u2713  TERIAKAN BERHASIL!"
