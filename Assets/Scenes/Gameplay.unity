--- !u!114 &173695826
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 173695824}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: fd876ae14a2f59f4bbe12385e9c412b3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  namaKontak: Nomor Tak Dikenal
  statusKontak: online
  warnaHeader: {r: 0.05, g: 0.32, b: 0.27, a: 1}
  warnaTeksHeader: {r: 1, g: 1, b: 1, a: 1}
  warnaChatBg: {r: 0.05, g: 0.12, b: 0.12, a: 1}
  warnaBubbleMasuk: {r: 0.2, g: 0.3, b: 0.35, a: 1}
  warnaTeksBubble: {r: 1, g: 1, b: 0.95, a: 1}
  pesanMasuk:
  - teks: "Hai Rara \U0001F60A Ini om yang tadi pagi di halte, yang nanya kamu sekolah
      di mana. Masih ingat kan?"
    delayDetik: 0.8
  - teks: "Om dapat nomor kamu dari temanmu, si Dina. Om bilang om kenal papamu,
      eh dia langsung kasih \U0001F604"
    delayDetik: 2.2
  - teks: "Nah, sekarang kita bisa ngobrol diam-diam ya. Fotoin kamu pakai seragam
      dong, jangan bilang siapa-siapa \U0001F92B"
    delayDetik: 2.4
  waktuPilihDetik: 8
  warnaTimer: {r: 1, g: 0.85, b: 0.3, a: 1}
  tampilkanTombolScreenshot: 1
  screenshotLabel: "\U0001F4F7 Screenshot Bukti"
  screenshotBonus: 100
  screenshotWarna: {r: 0.2, g: 0.62, b: 0.86, a: 1}
  aksiList:
  - label: "\U0001F6AB BLOKIR & CERITA ke ORTU"
    kategori: AMAN
    reaksi: "\u2713 HEBAT, RA! Kamu blokir nomornya lalu CERITA ke ortu. Itu kata
      sakti ke-3: CERITA. Jangan pernah simpan rahasia berbahaya dari orang dewasa
      yang kamu percaya!"
    bonusPoin: 500
    kurangiNyawa: 0
    warna: {r: 0.91, g: 0.3, b: 0.24, a: 1}
  - label: "\u260E LAPOR KPAI 021-31901556"
    kategori: AMAN
    reaksi: "\u2713 Hebat! Kamu lapor ke KPAI bersama ortu. Mereka akan tindak lanjut."
    bonusPoin: 500
    kurangiNyawa: 0
    warna: {r: 0.18, g: 0.62, b: 0.32, a: 1}
  - label: "\U0001F4AC Balas: 'Iya Om'"
    kategori: BAHAYA
    reaksi: "\u2716 GAWAT! Orang itu makin pede dan minta lokasi rumahmu. Kamu kehilangan
      1 nyawa. Orang asing di chat = sama bahayanya dengan di dunia nyata!"
    bonusPoin: 0
    kurangiNyawa: 1
    warna: {r: 0.5, g: 0.2, b: 0.2, a: 1}
  - label: "\u2753 Diamkan / Abaikan"
    kategori: RAGU
    reaksi: "\u26A0 Kamu diamkan. Tapi besok dia kirim chat lagi. Lebih baik BLOKIR
      lalu CERITA ke ortu \u2014 jangan dipendam sendiri."
    bonusPoin: 0
    kurangiNyawa: 0
    warna: {r: 0.95, g: 0.62, b: 0.07, a: 1}
  aksiSaatTimeout: 2
  tombolLanjutTeks: "\u25B6  Lanjut"
  warnaLanjut: {r: 0.2, g: 0.62, b: 0.86, a: 1}
  bgFullscreenSprite: {fileID: 0}
  bgFullscreenPreserveAspect: 0
  fontAsset: {fileID: 0}
  sortingOrder: 935
