  m_Script: {fileID: 11500000, guid: 8f4be36843210b341bd13d67fe037019, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  judulTeks: "\U0001F6E1  Quiz: Mana yang BOLEH, mana yang TIDAK BOLEH?"
  judulWarna: {r: 1, g: 0.85, b: 0.3, a: 1}
  judulUkuran: 30
  instruksiTeks: 'Tarik setiap chip ke ZONA AMAN atau ZONA BAHAYA.

    Setiap jawaban
    benar = poin. Waktu terbatas!'
  instruksiWarna: {r: 1, g: 1, b: 0.92, a: 0.85}
  instruksiUkuran: 18
  modeVisualNovel: 0
  vnPertanyaanTemplate: "Menurutmu, \u201C{PERILAKU}\u201D itu BOLEH atau TIDAK BOLEH
    dilakukan orang lain ke tubuhmu?"
  vnLabelBoleh: "\u2713  BOLEH"
  vnLabelTidakBoleh: "\u2716  TIDAK BOLEH"
  waktuDetik: 15
  warnaTimer: {r: 1, g: 0.85, b: 0.3, a: 1}
  warnaTimerKritis: {r: 0.91, g: 0.3, b: 0.24, a: 1}
  ukuranTimer: 28
  chips:
  - teks: Salam jabat tangan
    jawabanBenar: AMAN
  - teks: Peluk ortu/saudara
    jawabanBenar: AMAN
  - teks: Cek up dokter (didampingi)
    jawabanBenar: AMAN
  - teks: Disentuh paksa orang asing
    jawabanBenar: BAHAYA
  - teks: Diminta lepas baju oleh orang asing
    jawabanBenar: BAHAYA
  - teks: Disuruh simpan rahasia 'pertemuan kita'
    jawabanBenar: BAHAYA
  warnaZonaAman: {r: 0.1, g: 0.35, b: 0.22, a: 0.92}
  warnaZonaBahaya: {r: 0.4, g: 0.12, b: 0.12, a: 0.92}
  warnaBorderAman: {r: 0.45, g: 1, b: 0.65, a: 1}
  warnaBorderBahaya: {r: 1, g: 0.45, b: 0.45, a: 1}
  chipWarna: {r: 0.18, g: 0.2, b: 0.3, a: 0.95}
  chipTeksWarna: {r: 1, g: 1, b: 0.92, a: 1}
  chipBenarWarna: {r: 0.18, g: 0.62, b: 0.32, a: 0.95}
  chipSalahWarna: {r: 0.78, g: 0.2, b: 0.2, a: 0.95}
  chipUkuranTeks: 18
  chipUkuran: {x: 280, y: 60}
  namaAchievement: Penjaga Batas Tubuh
  bonusAllBenar: 200
  tombolLanjutTeks: "\u25B6  Lanjut"
  warnaLanjut: {r: 0.18, g: 0.62, b: 0.32, a: 1}
  bgFullscreenSprite: {fileID: 0}
  bgFullscreenPreserveAspect: 0
  narasiIntro:
  - pembicara: Narasi
    teks: Angkot terus melaju. Setelah kejadian tadi, Rara sudah pindah ke kursi
      lebih depan dan mencoba menenangkan napasnya.
  - pembicara: Rara
    teks: "\"Untung aku tadi berani bersuara dan menjauh\u2026 tapi jantungku masih
      berdebar. Aku perlu mengalihkan pikiran sebentar.\""
  - pembicara: Narasi
    teks: "Rara mengeluarkan buku catatan PR Kesehatan dari tas. Kebetulan bab terakhirnya
      justru soal ini: \u201CKenali Batas Tubuhmu \u2014 Mana yang Boleh, Mana yang
      Tidak.\u201D"
  - pembicara: Rara
    teks: "\"Justru sekarang aku makin paham kenapa bab ini penting. Ayo aku pelajari
      baik-baik \u2014 siapa yang BOLEH dan TIDAK BOLEH menyentuhku.\""
  narasiIntroAman: []
  narasiIntroRagu: []
  narasiIntroBahaya: []
  narasiOutro:
  - pembicara: Narasi
    teks: "Angkot masih melaju menuju sekolah. Rara menutup buku catatannya \u2014
      kini ia lebih paham soal batas tubuhnya sendiri."
  - pembicara: Rara
    teks: '"Aku merasa lebih siap sekarang. Tapi aku tetap harus waspada sampai turun
      nanti."'
