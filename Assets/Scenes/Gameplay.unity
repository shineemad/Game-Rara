  - Depan Rumah
  - Lorong Pemukiman
  - Halte & Persimpangan
  - Akses Sekolah
  eduCardPanel: {fileID: 0}
  eduCardContinueBtn: {fileID: 0}
  shoutButton: {fileID: 0}
  shoutGauge: {fileID: 0}
  shoutFillRate: 0.5
  shoutDecayRate: 0.3
  tutorialObstacle: {fileID: 0}
  encounter1:
    encounterName: "Encounter 1 \u2014 Orang Asing Penawar Permen"
    dialogSebelumPilihan:
    - speaker: Narasi
      portrait: {fileID: 0}
      text: Tiba-tiba seorang pria asing menghentikan langkah Rara...
    - speaker: Orang Asing
      portrait: {fileID: 0}
      text: '"Hei dek, bentar ya~!

        Mau permen nggak? Enak banget!

        Om
        punya banyak di warung, ikut bentar aja ya, deket kok!"'
    - speaker: Rara (dalam hati)
      portrait: {fileID: 0}
      text: 'Rara nggak kenal orang ini sama sekali!

        Dia nawarin permen
        DAN mau ngajak pergi... ini nggak bener!'
    pertanyaanRara: Gimana Rara harus merespons orang ini?
    portraitRara: {fileID: 0}
    pilihan:
    - label: '"NGGAK MAU! Aku nggak kenal Bapak!" (Teriak & lari ke tempat ramai)'
      category: AMAN
      gunakanPoinKustom: 0
      poinKustom: 0
      feedbackText: "\u2705 Bagus sekali! Rara menolak dengan tegas!\nOrang asing
        yang menawarkan hadiah dan mengajak pergi = TANDA BAHAYA!\nSelalu tolak dan
        pergi ke tempat yang ramai."
    - label: '"Makasih pak, tapi aku sudah mau telat sekolah..." (Menolak dengan
        alasan)'
      category: RAGU
      gunakanPoinKustom: 0
      poinKustom: 0
      feedbackText: "\u26A0\uFE0F Lumayan... Rara menolak, tapi kurang tegas.\nSebaiknya
        langsung pergi ke tempat yang lebih ramai\ndan ceritakan ke orang dewasa
        yang dipercaya."
    - label: '"Boleh~" (Ikut saja)'
      category: BAHAYA
      gunakanPoinKustom: 0
      poinKustom: 0
      feedbackText: "\u274C BAHAYA! Rara kehilangan \u2764 karena ikut orang asing!\nJANGAN
        PERNAH ikut dengan orang yang tidak dikenal,\napapun yang ditawarkan!"
  encounter2:
    encounterName: "Encounter 2 \u2014 Motor Nyasar Tanya Sekolah"
    dialogSebelumPilihan:
    - speaker: Narasi
      portrait: {fileID: 0}
      text: 'Sebuah motor matic berhenti pelan di sebelah Rara.

        Pengendaranya
        laki-laki, helm setengah terbuka, tersenyum lebar.'
    - speaker: Pengendara Motor
      portrait: {fileID: 0}
      text: "\"Eh dek, maaf nih\u2026\nKamu tau nggak SMP Harapan di mana?\nOm nyasar,
        mau anter ponakan.\""
    - speaker: Pengendara Motor
      portrait: {fileID: 0}
      text: '"Naik aja deh, kebetulan om searah.

        Daripada kamu jalan kepanasan,
        mending bareng om aja ya?"'
    - speaker: Rara (dalam hati)
      portrait: {fileID: 0}
      text: "Hmm\u2026 dia bilang nyasar tapi langsung nawarin tumpangan?\nOrang
        asing yang tiba-tiba ramah begini bisa jadi tanda bahaya."
    pertanyaanRara: Bagaimana Rara harus merespons orang ini?
    portraitRara: {fileID: 0}
    pilihan:
    - label: '"Maaf om, aku nggak boleh ikut orang asing!" (Mundur & lari ke tempat
        ramai)'
      category: AMAN
      gunakanPoinKustom: 0
      poinKustom: 0
      feedbackText: "\u2705 Tepat sekali!\nORANG TIDAK DIKENAL = JANGAN PERNAH IKUT,
        walau alasannya seramah apapun.\nKalau ditanya jalan, cukup tunjuk arah dari
        jauh \u2014 jangan dekati & jangan naik."
    - label: "\"SMP Harapan lurus aja om\u2026 maaf aku nggak bisa nganterin.\" (Jawab
        dari jauh)"
      category: RAGU
      gunakanPoinKustom: 0
      poinKustom: 0
      feedbackText: "\u26A0\uFE0F Lumayan \u2014 Rara nggak naik motor, tapi terlalu
        lama ngobrol.\nLebih baik langsung pergi ke tempat ramai. Jangan kasih info
        detail ke orang asing."
    - label: '"Boleh om, ayo!" (Naik motor)'
      category: BAHAYA
      gunakanPoinKustom: 0
      poinKustom: 0
      feedbackText: "\u274C BAHAYA! Rara hampir naik motor orang asing!\nNAIK KENDARAAN
        ORANG TAK DIKENAL = jalan menuju penculikan.\nKamu kehilangan \u2764. Ingat:
        \"Searah\" cuma alasan grooming yang umum dipakai."
  encounter3:
    encounterName: "Encounter 3 \u2014 Pesan Mencurigakan di HP"
    dialogSebelumPilihan:
    - speaker: Narasi
      portrait: {fileID: 0}
      text: "\U0001F4F1 HP Rara berbunyi! Ada pesan dari nomor tidak dikenal:\n\"Hei
        Rara, aku tau kamu lagi di jalan. Mau aku jemput?\""
    pertanyaanRara: Apa yang harus Rara lakukan dengan pesan ini?
    portraitRara: {fileID: 0}
    pilihan:
    - label: Screenshot lalu blokir nomor dan cerita ke Mama
      category: AMAN
      gunakanPoinKustom: 0
      poinKustom: 0
      feedbackText: "\u2705 Tepat! Screenshot sebagai bukti, blokir nomornya,\ndan
        SELALU ceritakan ke orang dewasa yang dipercaya."
    - label: 'Balas: "Siapa kamu?" (penasaran)'
      category: RAGU
      gunakanPoinKustom: 0
      poinKustom: 0
      feedbackText: "\u26A0\uFE0F Membalas pesan orang asing bisa berbahaya.\nLebih
        baik abaikan, blokir, dan lapor ke orang tua."
    - label: Ikuti ajakannya (sangat berbahaya!)
      category: BAHAYA
      gunakanPoinKustom: 0
      poinKustom: 0
      feedbackText: "\u274C SANGAT BERBAHAYA! Jangan pernah temui orang asing\nyang
        hanya kamu kenal lewat pesan/medsos!"
  autoMulaiTanpaIntro: 0
