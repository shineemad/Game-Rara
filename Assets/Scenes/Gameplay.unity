  warnaAtap: {r: 0.3, g: 0.2, b: 0.12, a: 1}
  warnaTiang: {r: 0.25, g: 0.18, b: 0.1, a: 1}
  warnaPapanInfo: {r: 0.2, g: 0.5, b: 0.3, a: 1}
  dialogIntro:
  - teks: Akhirnya sampai halte. Tapi... belum ada angkot satu pun yang lewat.
    latarSprite: {fileID: -9166084717782916886, guid: 031ec425ab0a66641b6bc3d8bd845a94, type: 3}
    tandaBahaya: 0
    tandaBahayaTeks: 
  - teks: Rara duduk menunggu. Suasana sepi, hanya terdengar suara daun tertiup angin.
    latarSprite: {fileID: -4485321536226006897, guid: 2231939df502380419d50999cfe6e7b8, type: 3}
    tandaBahaya: 0
    tandaBahayaTeks: 
  - teks: Tak lama, ada motor berhenti di seberang. Seorang pria asing turun dan
      menatap Rara dari kejauhan...
    latarSprite: {fileID: 2839294785017435275, guid: d4bc66ef44bfa9347bcd870d7cb287a2, type: 3}
    tandaBahaya: 0
    tandaBahayaTeks: 
  - teks: Pelan-pelan, pria itu berjalan mendekati halte.
    latarSprite: {fileID: -4865884503035749218, guid: 702100b688d389f4c9074865c8e44ca0, type: 3}
    tandaBahaya: 0
    tandaBahayaTeks: 
  dialogAwal:
  - teks: Hai, cantik! Sendirian aja nih? Om dari tadi merhatiin kamu lho.
    latarSprite: {fileID: 9220187793519253819, guid: a08a8d44cebc0cc44b9d1b0f248c652b, type: 3}
    tandaBahaya: 1
    tandaBahayaTeks: Orang asing tiba-tiba sok akrab & memperhatikanmu
  - teks: "Mau ke sekolah ya? Om kebetulan searah. Daripada nunggu angkot lama, bareng
      om aja yuk \u2014 gratis kok."
    latarSprite: {fileID: 3421342021128756210, guid: c24fc0d0988a66641bf4c16d9a0c9f2a, type: 3}
    tandaBahaya: 1
    tandaBahayaTeks: Memberi iming-iming / tumpangan gratis
  - teks: Eh, WA kamu berapa? Nanti om anter pulang sekolah ya. Rahasia aja, nggak
      usah bilang siapa-siapa.
    latarSprite: {fileID: -7726510151329706208, guid: ecceb6ef2d61f094cb92cb6b8a235080, type: 3}
    tandaBahaya: 1
    tandaBahayaTeks: Minta data pribadi & mengajak menyimpan rahasia
  pilihanAman: "\u201CMaaf Om, saya nggak kenal. TOLONG jangan ganggu saya!\u201D"
  pilihanRagu: "\u201CHmm... saya pikir-pikir dulu ya Om...\u201D"
  pilihanBahaya: "\u201CBoleh deh Om, ini WA saya...\u201D"
  reaksiAman:
    teks: "\u2713 HEBAT, RA! Kamu menolak TEGAS & bersuara keras.\nOrang-orang di
      halte langsung menoleh, pria itu salah tingkah lalu pergi.\n\nKamu melakukan
      3 hal benar: TIDAK (tolak tegas) \u2014 PERGI (menjauh) \u2014 CERITA (minta
      tolong). Nomor HP itu DATA PRIBADI, jangan diberi ke orang asing!"
    latarSprite: {fileID: 940904585648935168, guid: 23688e8a1f5938b41a4368bbb146f47c, type: 3}
    tandaBahaya: 0
    tandaBahayaTeks: 
  reaksiRagu:
    teks: "\u26A0 Kamu ragu menjawab, dan pria itu makin memaksa minta nomormu.\nUntung
      angkot keburu datang dan kamu cepat naik.\n\nLain kali jangan ragu. Ingat 3
      kata sakti: TIDAK \u2014 PERGI \u2014 CERITA. Kamu berhak menolak siapa pun
      yang membuatmu tidak nyaman."
    latarSprite: {fileID: 7132907415357354675, guid: ad8ca633496923b47922620bb015e585, type: 3}
    tandaBahaya: 0
    tandaBahayaTeks: 
  reaksiBahaya:
    teks: "\u2716 GAWAT! Kamu memberi nomor WA-mu ke orang asing. Tak lama lagi HP-mu
      akan dibanjiri chat aneh dari pria itu. Kamu kehilangan 1 nyawa.\n\nIngat:
      hadiah/iming-iming dari orang asing = RED FLAG grooming. Yang benar: TIDAK
      (tolak) \u2014 PERGI (menjauh) \u2014 CERITA (lapor orang dewasa tepercaya)."
    latarSprite: {fileID: 637440988520020479, guid: ee647dd71faf2b84988d03a4c74b67d0, type: 3}
    tandaBahaya: 0
    tandaBahayaTeks: 
  latarReaksiAman: {fileID: 940904585648935168, guid: 23688e8a1f5938b41a4368bbb146f47c, type: 3}
  latarReaksiRagu: {fileID: 0}
  latarReaksiBahaya: {fileID: 0}
  berikanBonusLaporSaatAman: 1
  kurangiNyawaSaatBahaya: 1
  tombolLanjutTeks: "\u25B6  Naik angkot"
  warnaAman: {r: 0.15, g: 0.68, b: 0.38, a: 1}
  warnaRagu: {r: 0.95, g: 0.62, b: 0.07, a: 1}
  warnaBahaya: {r: 0.91, g: 0.3, b: 0.24, a: 1}
  warnaNetral: {r: 0.2, g: 0.62, b: 0.86, a: 1}
  fontAsset: {fileID: 11400000, guid: dc36b3fdc14f47ebb36fd484a67e268a, type: 2}
  badgeJudul: "\u26A0  TANDA BAHAYA"
  badgeWarna: {r: 0.85, g: 0.18, b: 0.14, a: 0.95}
  badgeTeksWarna: {r: 1, g: 1, b: 1, a: 1}
  sortingOrder: 920
