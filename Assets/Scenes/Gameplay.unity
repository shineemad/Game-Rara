  m_EditorClassIdentifier: 
  autoTampilSaatStart: 0
  backgroundSprite: {fileID: 0}
  backgroundImageType: 1
  backgroundColor: {r: 0.05, g: 0.1, b: 0.08, a: 0.97}
  borderSprite: {fileID: 0}
  borderColor: {r: 0.45, g: 1, b: 0.65, a: 1}
  ornamenAtasSprite: {fileID: 0}
  ornamenAtasSize: {x: 220, y: 110}
  ornamenAtasOffsetY: 35
  tampilkanOverlay: 1
  overlaySprite: {fileID: 0}
  overlayColor: {r: 0, g: 0, b: 0, a: 0.82}
  judul: "\U0001F6E1\uFE0F  CARA MENJAGA DIRI \u2014 HARI 2"
  warnaJudul: {r: 0.45, g: 1, b: 0.65, a: 1}
  ukuranJudul: 32
  tipsList:
  - heading: "\u2728 3 KATA SAKTI saat merasa tidak aman:"
    isi: "\u2460 TIDAK!  \u2014 tolak dengan TEGAS & suara keras.\n\u2461 PERGI  
      \u2014 menjauh / pindah ke tempat ramai.\n\u2462 CERITA  \u2014 lapor orang
      dewasa yang kamu percaya.\nKamu TIDAK pernah salah karena menolak atau melapor."
    ikon: {fileID: 0}
    warnaHeading: {r: 0.45, g: 1, b: 0.65, a: 1}
    warnaIsi: {r: 1, g: 1, b: 0.85, a: 1}
  - heading: "\U0001F6AB ZONA PRIBADI tubuhmu:"
    isi: "\u2022 Bagian tubuh yang tertutup baju renang = milik kamu sendiri.\n\u2022
      Tidak ada yang boleh menyentuh / melihat / memotretnya.\n\u2022 Kalau ada yang
      mencoba \u2014 walau orang dikenal \u2014 itu BAHAYA. Lakukan: TIDAK, PERGI,
      CERITA."
    ikon: {fileID: 0}
    warnaHeading: {r: 0.45, g: 1, b: 0.65, a: 1}
    warnaIsi: {r: 1, g: 1, b: 0.85, a: 1}
  - heading: "\U0001F6A9 KENALI TANDA BAHAYA (grooming):"
    isi: "\u2022 Orang asing sok akrab & memberi iming-iming / hadiah gratis.\n\u2022
      Minta data pribadi (nomor HP, alamat, foto).\n\u2022 Mengajak menyimpan rahasia
      dari orang tua.\nSemua itu = RED FLAG. Jangan diladeni!"
    ikon: {fileID: 0}
    warnaHeading: {r: 0.45, g: 1, b: 0.65, a: 1}
    warnaIsi: {r: 1, g: 1, b: 0.85, a: 1}
  - heading: "\U0001F68C Aman di Angkot & Jalan:"
    isi: "\u2022 Duduk dekat Pak Supir / ibu-ibu, hindari pojok sepi.\n\u2022 Catat
      plat nomor & kabari orang tua.\n\u2022 Kalau ada yang aneh, turun di tempat
      ramai dan minta tolong."
    ikon: {fileID: 0}
    warnaHeading: {r: 0.45, g: 1, b: 0.65, a: 1}
    warnaIsi: {r: 1, g: 1, b: 0.85, a: 1}
  - heading: "\U0001F46E ORANG TEPERCAYA tempat lapor:"
    isi: "\u2022 Orang tua, guru, dan keluarga dekat.\n\u2022 Polisi, satpam, atau
      petugas berseragam.\n\u2022 Ibu-ibu / orang dewasa di tempat ramai.\nSimpan
      nomor mereka & beranikan diri bercerita."
    ikon: {fileID: 0}
    warnaHeading: {r: 0.45, g: 1, b: 0.65, a: 1}
    warnaIsi: {r: 1, g: 1, b: 0.85, a: 1}
  footerText: "\u260E Hotline:\nPolisi 110  |  Hotline Anak 129  |  KPAI 021-31901556"
  warnaFooter: {r: 1, g: 0.78, b: 0.2, a: 1}
  ukuranFooter: 18
  tombolLanjutTeks: "\u25B6  LANJUT"
  tombolSprite: {fileID: 0}
  tombolWarna: {r: 0.2, g: 0.65, b: 0.35, a: 1}
  tombolBorderColor: {r: 1, g: 0.78, b: 0.2, a: 1}
  tombolTeksWarna: {r: 1, g: 1, b: 1, a: 1}
  tombolUkuranTeks: 26
