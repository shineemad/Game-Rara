--- !u!114 &452308648
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 452308644}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c2163f048da8d624286c5daba35a3076, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  lines:
  - speakerName: Pemotor
    profile: {fileID: -855298285791758126, guid: d7ceffcd3effdfb47873a6705e22d046, type: 3}
    text: Hei adek! Mau bareng om ke sekolah? Naik motor lebih cepat lho daripada
      jalan kaki.
    choices: []
  - speakerName: Pemotor
    profile: {fileID: -855298285791758126, guid: d7ceffcd3effdfb47873a6705e22d046, type: 3}
    text: Tenang aja, om kenal sama gurumu kok. Ayo cepetan, nanti telat.
    choices:
    - label: Tidak, terima kasih. Saya jalan saja.
      category: AMAN
    - label: Em... siapa Om? Saya tidak kenal.
      category: RAGU
    - label: Boleh, Om! Kebetulan capek.
      category: BAHAYA
