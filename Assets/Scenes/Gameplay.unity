--- !u!114 &2093605799
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2093605797}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d4376afa7a0c88c4f9da3d814c7d3f10, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  judulTeks: "\U0001F4E2 SAATNYA LAPOR!"
  judulWarna: {r: 1, g: 0.45, b: 0.45, a: 1}
  judulUkuran: 38
  deskripsiTeks: "Pria yang tadi menyentuh bahumu kembali menggeser duduknya \u2014
    makin merapat!\nTAHAN tombol TERIAK (atau tahan SPACE) untuk memanggil Pak Supir.\n\nTahan
    selama {DURASI} detik sebelum waktu habis."
  deskripsiWarna: {r: 1, g: 1, b: 0.92, a: 0.95}
  deskripsiUkuran: 22
  tampilkanNarasiPembuka: 1
  vnPanelSprite: {fileID: 0}
  vnPortraitNarasi: {fileID: 0}
  vnPortraitRara: {fileID: 0}
  vnPortraitPria: {fileID: 0}
  vnLatarSprite: {fileID: 0}
  waktuWindow: 12
  durasiTahan: 1.5
  teriakLabel: "\U0001F50A  TAHAN: TERIAK!"
  teriakWarna: {r: 0.91, g: 0.3, b: 0.24, a: 1}
  teriakWarnaDitekan: {r: 0.2, g: 0.78, b: 0.4, a: 1}
  teriakUkuran: 28
  warnaBarBg: {r: 0.1, g: 0.1, b: 0.12, a: 1}
  warnaBarFill: {r: 0.2, g: 0.78, b: 0.4, a: 1}
  achievementName: Berani Lapor
  bonusBerhasil: 500
  reaksiBerhasil: "\u2713 Pak Supir mendengar dan langsung menepi! Penumpang lain
    ikut menoleh \u2014 pria itu salah tingkah lalu turun. Angkot kembali melaju
    dan Rara tiba di sekolah dengan SELAMAT."
  reaksiGagal: "\u2716 Rara terlalu takut untuk bersuara. Untung angkot keburu sampai
    di sekolah dan Rara cepat turun \u2014 tapi lain kali, beranikan diri TERIAK
    minta tolong, ya!"
  tampilkanNarasiPengejaran: 1
  pengejaranJudul: "\U0001F4E2 MINTA TOLONG SEKARANG!"
  pengejaranDeskripsi: "Pria asing yang tadi menyentuh bahumu menggeser duduknya
    lagi \u2014 makin merapat ke arah Rara!\nPak Supir ada di depan. Inilah saatnya
    CERITA: minta tolong orang dewasa.\n\nTAHAN tombol TERIAK \"PAK, TOLONG!\" (atau
    tahan SPACE) sebelum waktu habis ({DURASI} dtk)."
  pengejaranReaksiBerhasil: "\u2713 Rara berteriak \"PAK, TOLONG!\" sekencang-kencangnya!
    Pak Supir langsung menepi dan menegur pria itu. Penumpang lain ikut menoleh \u2014
    pria itu salah tingkah lalu turun. Angkot melaju lagi dan Rara tiba di sekolah
    dengan SELAMAT."
  pengejaranReaksiGagal: "\u2716 Rara terlalu takut untuk bersuara. Pria itu makin
    berani \u2014 untung angkot keburu sampai di sekolah dan Rara cepat turun. Rara
    selamat, tapi sangat ketakutan. Lain kali, berani TERIAK minta tolong Pak Supir,
    ya!"
  kategoriGagal: BAHAYA
  kurangiNyawaSaatGagal: 1
  tampilkanTombolDiam: 1
  diamLabel: "\U0001F610  Diam saja, takut..."
  warnaDiam: {r: 0.55, g: 0.45, b: 0.2, a: 1}
  tombolLanjutTeks: "\u25B6  Lanjut ke Kartu Edukasi"
  warnaLanjut: {r: 0.2, g: 0.62, b: 0.86, a: 1}
  fontAsset: {fileID: 0}
  sortingOrder: 940
  modeVisualNovel: 0
  vnTeriakLabel: "\U0001F4E2  TERIAK panggil Pak Supir!"
  gunakanMikrofon: 1
  sensitivitasMic: 12
  ambangTeriak: 0.6
  teriakLabelMic: "\U0001F399  TERIAK ke mic!"
